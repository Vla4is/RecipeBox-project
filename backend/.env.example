# Backend server
# Used to sign login tokens. Replace with a long random secret in real environments.
JWT_SECRET=replace_with_a_long_random_secret

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace_with_database_password
DB_NAME=recipebox
DB_MAINTENANCE_DB=postgres

# Recipe seed behavior
# Set to false if you do not want startup migrations to seed demo recipes.
AUTO_SEED_RECIPES=true

# Premium recipe chatbot
# Master switch for the chatbot API and UI access checks.
CHATBOT_ENABLED=true

# Keep true for production. Set false only for local testing without premium checks.
CHATBOT_REQUIRE_PREMIUM=true

# OpenAI-compatible chat completions endpoint.
# OpenAI example:
CHATBOT_API_URL=https://api.openai.com/v1/chat/completions
# DeepSeek example:
# CHATBOT_API_URL=https://api.deepseek.com/chat/completions

# Provider API token/key. Never commit a real value.
CHATBOT_API_KEY=replace_with_openai_or_deepseek_api_key

# Provider model name.
# OpenAI examples: gpt-4o-mini, gpt-4.1-mini
# DeepSeek examples: deepseek-chat
CHATBOT_MODEL=gpt-4o-mini

# System prompt injected before recipe context and chat history.
CHATBOT_SYSTEM_PROMPT=You are RecipeBox's premium cooking assistant. Give concise, practical cooking advice based on the recipe, ingredients, steps, timing, and the user's question. If you are unsure, say so clearly.

# Optional examples for response style.
# Accepts either OpenAI-style message objects or any JSON value that can be summarized into the prompt.
CHATBOT_EXAMPLES_JSON=[]

# Chat history retention and limits.
CHATBOT_HISTORY_DAYS=30
CHATBOT_MAX_HISTORY_MESSAGES=12
CHATBOT_MAX_USER_MESSAGE_CHARS=1000
CHATBOT_SEARCH_LIMIT=5
